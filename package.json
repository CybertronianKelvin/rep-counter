{
  "name": "rep-counter",
  "version": "1.0.0",
  "description": "Zero-dependency rep counting engine for pose detection. Works with any pose model (MediaPipe, MoveNet, PoseNet).",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src tests"
  },
  "keywords": [
    "fitness",
    "exercise",
    "rep",
    "counter",
    "pose",
    "mediapipe",
    "movenet",
    "workout"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "@types/jest": "^29.5.0"
  }
}